{
  "name": "endfield-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "build:operators": "tsx scripts/build-operators-from-excel.ts",
    "watch:operators": "chokidar \"data/excel/*.xlsx\" -c \"npm run build:operators\"",
    "dev:all": "npm run build:operators && concurrently \"npm run watch:operators\" \"next dev\""
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^6.19.0",
    "@supabase/supabase-js": "^2.105.4",
    "cheerio": "^1.2.0",
    "lucide-react": "^1.8.0",
    "next": "^16.2.2",
    "next-auth": "^5.0.0-beta.31",
    "postcss": "^8.5.8",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/cheerio": "^0.22.35",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "^16.2.2",
    "prisma": "^6.19.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "xlsx": "^0.18.5"
  }
}
