generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("SUPABASE_DATABASE_URL")
  directUrl = env("SUPABASE_DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  nickname      String?   @unique
  role          String    @default("USER")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts             Account[]
  sessions             Session[]
  simulatorState       SimulatorState?
  materialInventory    UserMaterialInventory[]
  operatorSettings     UserOperatorSetting[]
  operatorSettingLikes UserOperatorSettingLike[]

  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SimulatorState {
  id        String   @id @default(cuid())
  userId    String   @unique
  state     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserMaterialInventory {
  id        String   @id @default(cuid())
  userId    String
  material  String
  quantity  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, material])
  @@index([userId])
}

model UserOperatorSetting {
  id          String   @id @default(cuid())
  userId      String
  type        String
  title       String
  description String?
  cycle       Json     @default("[]")
  slots       Json
  nickname    String?
  viewCount   Int      @default(0)
  likeCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes UserOperatorSettingLike[]

  @@index([userId])
  @@index([userId, type])
  @@index([updatedAt])
  @@index([type, updatedAt])
  @@index([createdAt])
  @@index([likeCount, createdAt])
  @@index([viewCount, createdAt])
}

model UserOperatorSettingLike {
  id        String   @id @default(cuid())
  userId    String
  settingId String
  createdAt DateTime @default(now())

  user    User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  setting UserOperatorSetting @relation(fields: [settingId], references: [id], onDelete: Cascade)

  @@unique([userId, settingId])
  @@index([settingId])
}
